{
  "productName": "MoA 문서 변환기",
  "version": "1.0.0",
  "identifier": "com.zeroclaw.moa.docconverter",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MoA 문서 변환기",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "icon": [],
    "resources": [
      "../backend/**/*.py",
      "../backend/**/*.txt",
      "../config/**/*"
    ],
    "windows": {
      "nsis": {
        "languages": ["Korean", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "dialog": {},
    "shell": { "open": true },
    "fs": {
      "scope": {
        "allow": ["**"],
        "deny": []
      }
    }
  }
}
