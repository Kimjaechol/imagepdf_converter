{
  "productName": "MoA 문서 변환기",
  "version": "1.0.0",
  "identifier": "com.zeroclaw.moa.docconverter",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MoA 문서 변환기",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../backend/**/*.py",
      "../backend/**/*.txt",
      "../config/**/*",
      "../build_output/portable_python/**/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "languages": ["Korean", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "shell": { "open": true }
  }
}
