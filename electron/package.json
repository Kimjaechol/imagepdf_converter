{
  "name": "pdf-converter",
  "version": "1.0.0",
  "description": "PDF 변환기 - PDF를 HTML/Markdown으로 변환",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.pdfconverter.app",
    "productName": "PDF 변환기",
    "files": [
      "src/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "../build_output/portable_python",
        "to": "portable_python"
      },
      {
        "from": "../build_output/app_backend",
        "to": "app_backend"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "public/icon.png",
      "artifactName": "PDF-변환기-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PDF 변환기",
      "installerLanguages": ["ko"],
      "language": "1042",
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "public/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "PDF-변환기-${version}-macOS.${ext}"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "public/icon.png",
      "category": "Office",
      "artifactName": "PDF-변환기-${version}-Linux.${ext}"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
