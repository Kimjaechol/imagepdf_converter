  "latin_numeral_confusion": {
    "_description": "숫자 ↔ 영문자 혼동 쌍 (LLM 문맥 교정용 참조)",
    "groups": [
      {"chars": ["0", "O", "o"], "rule": "금액/날짜=숫자, 영단어=영문자"},
      {"chars": ["1", "l", "I", "|", "ㅣ"], "rule": "숫자맥락=1, 영단어=I/l, 로마자번호=Ⅰ"},
      {"chars": ["5", "S", "s"], "rule": "숫자맥락=5, 영단어=S"},
      {"chars": ["8", "B"], "rule": "숫자맥락=8, 영단어=B"},
      {"chars": ["2", "Z", "z"], "rule": "숫자맥락=2, 계약서=乙"},
      {"chars": ["6", "G", "b"], "rule": "숫자맥락=6, 영단어=G/b"},
      {"chars": ["9", "g", "q"], "rule": "숫자맥락=9, 영단어=g/q"},
      {"chars": ["rn", "m"], "rule": "영단어 사전 매칭"},
      {"chars": ["cl", "d"], "rule": "영단어 사전 매칭"},
      {"chars": ["vv", "w"], "rule": "영단어 사전 매칭"}
    ]
  },
  "korean_symbol_confusion": {
    "_description": "한글 자모 ↔ 기호 혼동 (LLM 문맥 교정용 참조)",
    "groups": [
      {"chars": ["ㅁ", "□"], "rule": "한글자모=ㅁ, 도형/체크박스=□"},
      {"chars": ["ㅇ", "O", "0"], "rule": "한글자모=ㅇ, 영문=O, 숫자=0"},
      {"chars": ["—", "-", "ㅡ", "一"], "rule": "구두점=—, 범위=-, 한글자모=ㅡ, 한자=一"},
      {"chars": [",", "."], "rule": "저해상도에서 혼동, 금액천단위=쉼표, 소수점=점"},
      {"chars": [":", ";"], "rule": "시간=콜론, 문장구분=세미콜론"}
    ]
  },
