{
  "outputDirectory": "homepage",
  "buildCommand": null,
  "framework": null,
  "rewrites": [
    { "source": "/payment/success", "destination": "/payment-success.html" },
    { "source": "/payment/toss/success", "destination": "/payment-success.html" },
    { "source": "/payment/fail", "destination": "/payment-fail.html" },
    { "source": "/payment/toss/fail", "destination": "/payment-fail.html" },
    { "source": "/payment/cancel", "destination": "/payment-fail.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.css|.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
