# ===========================================================================
# MoA 문서 변환기 – 환경변수 설정 가이드
# ===========================================================================
#
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요:
#   cp .env.example .env
#
# Railway 배포 시에는 Railway 대시보드 > Variables 탭에서 설정합니다.
# (코드에 실제 키를 커밋하지 마세요!)
# ===========================================================================

# Gemini API key (for VLM reading order + text correction)
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================================================
# Upstage API Key (운영자 전용 – Railway 환경변수로만 설정)
# ===========================================================================
#
# ⚠️  이 키는 운영자만 Railway 대시보드 > Variables 탭에서 설정합니다.
# ⚠️  사용자가 접근하거나 수정할 수 없습니다 (API 엔드포인트 없음).
#
# Upstage Document Parse API는 PDF 변환 시 사용됩니다 (upstage_hybrid 모드).
# https://console.upstage.ai 에서 API 키를 발급받으세요.
#
UPSTAGE_API_KEY=your-upstage-api-key-here

# Pipeline config path (optional, defaults to config/pipeline_config.yaml)
# PIPELINE_CONFIG=/path/to/pipeline_config.yaml

# Backend server port (optional, defaults to 8765)
# PORT=8765

# ===========================================================================
# Supabase (사용자 인증 및 프로필 저장)
# ===========================================================================
#
# Supabase 프로젝트 생성 후 Settings > API 에서 확인:
#   - Project URL
#   - anon/public key
#   - service_role key (서버 전용, 노출 금지)
#
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================================================================
# Stripe / Toss Payments (결제 기능 - 현재 비활성)
# ===========================================================================
#
# 현재는 결제 없이 수동 크레딧 충전 모드로 운영 중입니다.
# 결제 기능 활성화 시 아래 8개 변수의 주석을 해제하고 값을 설정하세요.
#
# ── Stripe (해외 카드 결제) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://yourdomain.com/payment/success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=https://yourdomain.com/payment/cancel
#
# ── Toss Payments (한국 결제: 카카오페이, 네이버페이, 카드, 계좌이체) ──
# TOSS_CLIENT_KEY=test_ck_...
# TOSS_SECRET_KEY=test_sk_...
# TOSS_SUCCESS_URL=https://yourdomain.com/payment/toss/success
# TOSS_FAIL_URL=https://yourdomain.com/payment/toss/fail

# ===========================================================================
# Exchange Rate (환율)
# ===========================================================================
#
# KRW/USD 환율은 자동으로 6시간마다 업데이트됩니다.
# 아래 값은 API 호출 실패 시 사용되는 기본값입니다.
# 자동 업데이트를 원치 않으면 이 값을 수동으로 설정하세요.
#
KRW_USD_RATE=1350

# ===========================================================================
# Cloudflare R2 (대용량 이미지 PDF 업로드용 오브젝트 스토리지)
# ===========================================================================
#
# 하이브리드 아키텍처: 대용량 이미지 PDF는 Railway를 거치지 않고
# R2로 직접 업로드됩니다. Railway는 제어 흐름(인증, 과금, Upstage 호출)만 담당합니다.
#
# ── 설정 가이드 ──
# 1. Cloudflare 대시보드 > R2 Object Storage > Create Bucket
# 2. 버킷 이름: moa-documents (또는 원하는 이름)
# 3. R2 > Manage R2 API Tokens > Create API token
#    - Permissions: Object Read & Write
#    - Specify bucket: 생성한 버킷 선택
# 4. Account ID: Cloudflare 대시보드 URL에서 확인
#    (https://dash.cloudflare.com/<ACCOUNT_ID>/r2)
#
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=moa-documents
# R2_PUBLIC_URL=https://your-custom-domain.com  # Optional: custom domain for public reads
