{
  "name": "moa-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Tiptap editor bundle for MoA document converter",
  "scripts": {
    "build": "esbuild js/tiptap-bundle.js --bundle --outfile=js/tiptap.bundle.js --format=esm --target=es2020 --minify",
    "watch": "esbuild js/tiptap-bundle.js --bundle --outfile=js/tiptap.bundle.js --format=esm --target=es2020 --watch"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@tiptap/extension-table": "^2.11.0",
    "@tiptap/extension-table-row": "^2.11.0",
    "@tiptap/extension-table-cell": "^2.11.0",
    "@tiptap/extension-table-header": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/extension-text-align": "^2.11.0",
    "@tiptap/extension-image": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "turndown": "^7.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
